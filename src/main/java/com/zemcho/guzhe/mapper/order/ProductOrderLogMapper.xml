<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zemcho.guzhe.mapper.order.ProductOrderLogMapper">
    <sql id="fields">
        order_id,
        order_no,
        user_id,
        user_name,
        handle,
        details,
        create_time
    </sql>

    <insert id="insert">
        INSERT INTO `product_order_log`
        (<include refid="fields"/>)
        VALUES
        (
        #{data.orderId},
        #{data.orderNo},
        #{data.userId},
        #{data.userName},
        #{data.handle},
        #{data.details},
        #{data.createTime}
        )
    </insert>

    <select id="selectByOrderId" resultType="com.zemcho.guzhe.entity.order.ProductOrderLog">
        SELECT *
        FROM `product_order_log`
        WHERE order_id = #{orderId}
        ORDER BY `id` DESC
    </select>
</mapper>