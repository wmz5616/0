<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zemcho.guzhe.mapper.product.ProductCategoryRelationMapper">


    <delete id="deleteByProductId">
        DELETE FROM product_category_relation WHERE product_id = #{id}
    </delete>

    <insert id="insertBatch" keyProperty="id" useGeneratedKeys="true">
        INSERT INTO `product_category_relation` (
        product_id,
        category_id
        ) VALUES
        <foreach collection="data" item="item" separator=",">
            (
            #{item.productId},
            #{item.categoryId}
            )
        </foreach>
    </insert>

    <delete id="deleteByProductIds">
        DELETE FROM product_category WHERE id IN
        <foreach item="item" collection="productIds" separator="," open="(" close=")">
            #{item}
        </foreach>
    </delete>
</mapper>