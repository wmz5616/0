<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zemcho.guzhe.mapper.shop.IndustryCategoryShopMapper">

    <insert id="insertBatch">
        INSERT INTO `shop_industry_category` ( `industry_category_id`, `shop_id` )
        VALUES
        <foreach collection="list" item="item" separator=",">
            ( #{item.industryCategoryId}, #{item.shopId} )
        </foreach>
    </insert>

    <delete id="deleteByShopIds">
        DELETE FROM `shop_industry_category`
        WHERE `shop_id` IN
        <foreach collection="shopIds" item="shopId" separator="," open="(" close=")">
            #{shopId}
        </foreach>
    </delete>

    <select id="selectIndustryIdsByShopId" resultType="java.lang.Integer">
        SELECT `industry_category_id`
        FROM `shop_industry_category`
        WHERE `shop_id` = #{searchId}
    </select>
</mapper>
