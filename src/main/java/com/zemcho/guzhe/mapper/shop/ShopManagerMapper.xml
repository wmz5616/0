<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.zemcho.guzhe.mapper.shop.ShopManagerMapper">

    <!-- 根据ID查询 -->
    <select id="selectById" resultType="com.zemcho.guzhe.entity.shop.ShopManager">
        SELECT *
        FROM `shop_manager`
        WHERE id = #{id}
    </select>


    <!-- 根据商家ID查询 -->
    <select id="selectByShopId" resultType="com.zemcho.guzhe.entity.shop.ShopManager">
        SELECT *
        FROM `shop_manager`
        WHERE shop_id = #{shopId}
        ORDER BY sort ASC
    </select>

    <select id="selectByIds" resultType="com.zemcho.guzhe.entity.shop.ShopManager">
        SELECT *
        FROM `shop_manager`
        <where>
            <if test="ids != null and ids.size > 0">
                id IN
                <foreach item="id" collection="ids" separator="," open="(" close=")">
                    #{id}
                </foreach>
            </if>
        </where>

    </select>

    <!-- 新增 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `shop_manager` (
            shop_id,
            sort,
            name,
            phone,
            head_manager
        ) VALUES (
                     #{param.shopId},
                     #{param.sort},
                     #{param.name},
                     #{param.phone},
                     #{param.headManager}
                 )
    </insert>

    <!-- 更新只修改姓名和电话 -->
    <update id="update">
        UPDATE `shop_manager`
        <set>
            <if test="data.name != null and data.name != ''">
                name = #{data.name},
            </if>
            <if test="data.phone != null and data.phone != ''">
                phone = #{data.phone},
            </if>
        </set>
        WHERE id = #{data.id}
    </update>

    <!-- 根据ID删除 -->
    <delete id="deleteByIds">
        DELETE FROM `shop_manager`
        <where>
            <foreach item="id" collection="ids" separator="OR" open="(" close=")">
                id = #{id}
            </foreach>
        </where>
    </delete>

    <select id="selectByShopIdAndPhone" resultType="com.zemcho.guzhe.entity.shop.ShopManager">
        SELECT *
        FROM `shop_manager`
        WHERE shop_id = #{shopId}
        AND phone = #{phone}
        LIMIT 1
    </select>
    <delete id="deleteByShopId">
        DELETE FROM `shop_manager`
        WHERE shop_id = #{shopId}
    </delete>

    <select id="selectShopIdsByPhone" resultType="java.lang.Integer">
        select shop_id from shop_manager where phone = #{phone}
    </select>
</mapper>