<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zemcho.guzhe.mapper.sys.ConfigMapper">
    <select id="selectConfigListByType" resultType="com.zemcho.guzhe.entity.sys.Config">
        SELECT *
        FROM `sys_config`
        <where>
            <if test="type != null "> and type = #{type}</if>
        </where>
        ORDER BY id desc
    </select>

    <update id="updateConfigValueByKey">
        UPDATE `sys_config`
        SET `value` = #{value}
        WHERE `key` = #{key}
    </update>
</mapper>