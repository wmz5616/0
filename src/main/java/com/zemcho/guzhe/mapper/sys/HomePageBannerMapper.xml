<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.zemcho.guzhe.mapper.sys.HomePageBannerMapper">

    <insert id="insert" parameterType="com.zemcho.guzhe.entity.sys.HomePageBanner">
        insert into home_page_banner(pic, type, url, status, sort, create_time)
        values (#{data.pic}, #{data.type}, #{data.url}, #{data.status}, #{data.sort}, #{data.createTime})
    </insert>

    <update id="update" parameterType="com.zemcho.guzhe.entity.sys.HomePageBanner">
        update home_page_banner
        <set>
            <if test="data.pic != null and data.pic!=''">
                pic = #{data.pic},
            </if>
            <if test="data.type != null">
                type = #{data.type},
            </if>
            <if test="data.url != null and data.url != ''">
                url = #{data.url},
            </if>
            <if test="data.status != null">
                status = #{data.status},
            </if>
            <if test="data.sort != null">
                sort = #{data.sort},
            </if>
        </set>
        where id = #{data.id}
    </update>

    <delete id="deleteByIds" parameterType="java.util.List">
        delete from home_page_banner where id in
        <foreach item="item" collection="ids" open="(" separator="," close=")">
            #{item}
        </foreach>
    </delete>

    <update id="updateStatusByIds">
        UPDATE `home_page_banner`
        SET status = #{status}
        WHERE id IN
        <foreach collection="ids" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </update>

    <select id="selectMaxSort" resultType="java.lang.Integer">
        SELECT MAX(sort)
        FROM `home_page_banner`
    </select>
</mapper>